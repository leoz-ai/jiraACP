{
  "name": "@jiraacp/cli",
  "version": "2026.405.4",
  "description": "AI-powered Jira pipeline CLI: Ticket → Code → GitHub → Deploy → Notify",
  "type": "module",
  "bin": {
    "jiraACP": "./dist/cli.js",
    "jiraACP-mcp": "./dist/mcp.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js start",
    "stop": "node dist/cli.js stop",
    "restart": "npm run stop && npm run start",
    "version:date": "node scripts/version-date.mjs",
    "release": "npm run build && npm run version:date && npm publish",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^21.0.0",
    "@clack/prompts": "^0.9.0",
    "axios": "^1.7.0",
    "commander": "^12.0.0",
    "grammy": "^1.30.0",
    "picocolors": "^1.1.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "jira",
    "claude",
    "ai",
    "pipeline",
    "automation",
    "mcp"
  ],
  "license": "MIT"
}
